<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_service_order" model="ir.actions.act_window">
        <field name="name">Service Orders</field>
        <field name="res_model">service.order</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Click "New" to create your first service order!</p>
        </field>
    </record>

    <menuitem id="menu_service_order_root" name="Dịch vụ" web_icon="base,static/description/services.png" sequence="10"/>
    <menuitem id="menu_service_order_main" name="Đơn dịch vụ" parent="menu_service_order_root" action="action_service_order" sequence="1"/>
    <menuitem id="menu_service_order_partner" name="Khách hàng" parent="menu_service_order_root" action="action_service_order_partner" sequence="2"/>
</odoo>
